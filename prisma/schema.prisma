generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  member
}

enum UserStatus {
  active
  inactive
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum AcquisitionChannel {
  organic
  paid_ads
  referral
  content
  outbound_sales
  partnership
  other
}

enum FieldType {
  text
  number
  date
  select
  email
}

enum EntityType {
  employee
  client
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum TimeOffAccrualMethod {
  fixed_annual
  monthly
}

enum TimeOffRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum SavedViewType {
  grid
  kanban
}

enum SavedViewVisibility {
  personal
  shared
}

model Tenant {
  id                      String                   @id @default(uuid())
  name                    String
  slug                    String                   @unique
  status                  TenantStatus             @default(active)
  createdAt               DateTime                 @default(now())
  companySize             String?
  industry                String?
  country                 String?
  acquisitionChannel      AcquisitionChannel?
  users                   User[]
  employees               Employee[]
  clients                 Client[]
  customFieldDefns        CustomFieldDefinition[]
  customFieldValues       CustomFieldValue[]
  invitations             Invitation[]
  statusDefinitions       StatusDefinition[]
  statusHistory           StatusHistoryEntry[]
  timeOffPolicies         TimeOffPolicyDefinition[]
  employeeTimeOffPolicies EmployeeTimeOffPolicy[]
  timeOffRequests         TimeOffRequest[]
  savedViews              SavedView[]
  publicForms             PublicForm[]
}

model User {
  id               String               @id @default(uuid())
  firstName        String
  lastName         String
  phone            String
  email            String               @unique
  passwordHash     String
  role             UserRole             @default(member)
  status           UserStatus           @default(active)
  tenantId         String?
  tenant           Tenant?              @relation(fields: [tenantId], references: [id])
  sessions         Session[]
  sentInvitations  Invitation[]
  employee         Employee?
  statusChanges    StatusHistoryEntry[]
  savedViews       SavedView[]
  acceptedTermsAt  DateTime?
}

model Employee {
  id                       String                  @id @default(uuid())
  firstName                String
  lastName                 String
  email                    String
  department               String
  statusId                 String
  statusDefn               StatusDefinition        @relation(fields: [statusId], references: [id])
  managerId                String?
  manager                  Employee?               @relation("EmployeeManager", fields: [managerId], references: [id])
  reports                  Employee[]              @relation("EmployeeManager")
  tenantId                 String
  tenant                   Tenant                  @relation(fields: [tenantId], references: [id])
  createdAt                DateTime                @default(now())
  userId                   String?                 @unique
  user                     User?                   @relation(fields: [userId], references: [id])
  invitations              Invitation[]
  timeOffPolicies          EmployeeTimeOffPolicy[]
  timeOffRequestsMade      TimeOffRequest[]         @relation("TimeOffRequestEmployee")
  timeOffRequestsToApprove TimeOffRequest[]         @relation("TimeOffRequestApprover")

  @@unique([tenantId, email])
}

model Client {
  id              String               @id @default(uuid())
  firstName       String
  lastName        String
  email           String
  company         String
  statusId        String
  statusDefn      StatusDefinition     @relation(fields: [statusId], references: [id])
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  createdAt       DateTime             @default(now())

  @@unique([tenantId, email])
}

model StatusDefinition {
  id         String               @id @default(uuid())
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  entityType EntityType
  name       String
  color      String?
  order      Int                  @default(0)
  isDefault  Boolean              @default(false)
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  employees  Employee[]
  clients    Client[]

  @@index([tenantId, entityType])
}

model StatusHistoryEntry {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  entityType      EntityType
  entityId        String
  fromStatusName  String?
  toStatusName    String
  changedByUserId String
  changedBy       User       @relation(fields: [changedByUserId], references: [id])
  changedAt       DateTime   @default(now())

  @@index([tenantId, entityType, entityId])
}

model TimeOffPolicyDefinition {
  id                  String                  @id @default(uuid())
  tenantId            String
  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  name                String
  color               String?
  accrualMethod       TimeOffAccrualMethod    @default(fixed_annual)
  daysPerYear         Float
  isPaid              Boolean                 @default(true)
  requiresApproval    Boolean                 @default(true)
  isActive            Boolean                 @default(true)
  createdAt           DateTime                @default(now())
  employeeAssignments EmployeeTimeOffPolicy[]
  requests            TimeOffRequest[]

  @@index([tenantId])
}

model TimeOffRequest {
  id             String                @id @default(uuid())
  tenantId       String
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  employeeId     String
  employee       Employee              @relation("TimeOffRequestEmployee", fields: [employeeId], references: [id])
  timeOffPolicyId String
  timeOffPolicy  TimeOffPolicyDefinition @relation(fields: [timeOffPolicyId], references: [id])
  startDate      DateTime
  endDate        DateTime
  daysRequested  Float
  note           String?
  status         TimeOffRequestStatus  @default(pending)
  approverId     String?
  approver       Employee?             @relation("TimeOffRequestApprover", fields: [approverId], references: [id])
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime              @default(now())

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

model EmployeeTimeOffPolicy {
  id             String                  @id @default(uuid())
  tenantId       String
  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  employeeId     String
  employee       Employee                @relation(fields: [employeeId], references: [id])
  timeOffPolicyId String
  timeOffPolicy  TimeOffPolicyDefinition @relation(fields: [timeOffPolicyId], references: [id])
  assignedAt     DateTime                @default(now())

  @@unique([employeeId, timeOffPolicyId])
  @@index([tenantId])
}

model CustomFieldDefinition {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  name        String
  entityType  EntityType
  fieldType   FieldType
  options     String?            // JSON-encoded options for select fields
  required    Boolean            @default(false)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  values      CustomFieldValue[]
}

model CustomFieldValue {
  id                      String                  @id @default(uuid())
  tenantId                String
  tenant                  Tenant                  @relation(fields: [tenantId], references: [id])
  customFieldDefinitionId String
  customFieldDefinition   CustomFieldDefinition   @relation(fields: [customFieldDefinitionId], references: [id])
  entityType              EntityType
  entityId                String
  value                   String
  createdAt               DateTime                @default(now())

  @@index([tenantId, entityType, entityId])
}

model PublicForm {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  entityType   EntityType
  name         String
  slug         String
  fieldsConfig String     // JSON-encoded array of {key, required} — optional fields only (department/company + cf:<id>); firstName/lastName/email are always shown and required
  thankYouMessage String? // shown after a successful submit; falls back to a generic message when null
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model SavedView {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  entityType      EntityType
  createdByUserId String
  createdBy       User                @relation(fields: [createdByUserId], references: [id])
  name            String
  type            SavedViewType       @default(grid)
  visibility      SavedViewVisibility @default(personal)
  filters         String?             // JSON-encoded array of {field, operator, value}
  sortBy          String?             // JSON-encoded {field, direction}
  groupByField    String?             // kanban only: "status" or a CustomFieldDefinition id (select type)
  createdAt       DateTime            @default(now())

  @@index([tenantId, entityType])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Invitation {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  email           String
  role            UserRole         @default(member)
  token           String           @unique
  status          InvitationStatus @default(pending)
  invitedByUserId String
  invitedBy       User             @relation(fields: [invitedByUserId], references: [id])
  employeeId      String?
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
}
