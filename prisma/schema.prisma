generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  member
}

enum UserStatus {
  active
  inactive
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum FieldType {
  text
  number
  date
  select
  email
}

enum EntityType {
  employee
  client
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

model Tenant {
  id                   String                 @id @default(uuid())
  name                 String
  slug                 String                 @unique
  status               TenantStatus           @default(active)
  createdAt            DateTime               @default(now())
  users                User[]
  employees            Employee[]
  clients              Client[]
  customFieldDefns     CustomFieldDefinition[]
  customFieldValues    CustomFieldValue[]
  invitations          Invitation[]
  statusDefinitions    StatusDefinition[]
  statusHistory        StatusHistoryEntry[]
}

model User {
  id               String               @id @default(uuid())
  firstName        String
  lastName         String
  phone            String
  email            String               @unique
  passwordHash     String
  role             UserRole             @default(member)
  status           UserStatus           @default(active)
  tenantId         String?
  tenant           Tenant?              @relation(fields: [tenantId], references: [id])
  sessions         Session[]
  sentInvitations  Invitation[]
  employee         Employee?
  statusChanges    StatusHistoryEntry[]
}

model Employee {
  id              String               @id @default(uuid())
  firstName       String
  lastName        String
  email           String
  department      String
  statusId        String
  statusDefn      StatusDefinition     @relation(fields: [statusId], references: [id])
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  createdAt       DateTime             @default(now())
  userId          String?              @unique
  user            User?                @relation(fields: [userId], references: [id])
  invitations     Invitation[]

  @@unique([tenantId, email])
}

model Client {
  id              String               @id @default(uuid())
  firstName       String
  lastName        String
  email           String
  company         String
  statusId        String
  statusDefn      StatusDefinition     @relation(fields: [statusId], references: [id])
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  createdAt       DateTime             @default(now())

  @@unique([tenantId, email])
}

model StatusDefinition {
  id         String               @id @default(uuid())
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  entityType EntityType
  name       String
  color      String?
  order      Int                  @default(0)
  isDefault  Boolean              @default(false)
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  employees  Employee[]
  clients    Client[]

  @@index([tenantId, entityType])
}

model StatusHistoryEntry {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  entityType      EntityType
  entityId        String
  fromStatusName  String?
  toStatusName    String
  changedByUserId String
  changedBy       User       @relation(fields: [changedByUserId], references: [id])
  changedAt       DateTime   @default(now())

  @@index([tenantId, entityType, entityId])
}

model CustomFieldDefinition {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  name        String
  entityType  EntityType
  fieldType   FieldType
  options     String?            // JSON-encoded options for select fields
  required    Boolean            @default(false)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  values      CustomFieldValue[]
}

model CustomFieldValue {
  id                      String                  @id @default(uuid())
  tenantId                String
  tenant                  Tenant                  @relation(fields: [tenantId], references: [id])
  customFieldDefinitionId String
  customFieldDefinition   CustomFieldDefinition   @relation(fields: [customFieldDefinitionId], references: [id])
  entityType              EntityType
  entityId                String
  value                   String
  createdAt               DateTime                @default(now())

  @@index([tenantId, entityType, entityId])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Invitation {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  email           String
  role            UserRole         @default(member)
  token           String           @unique
  status          InvitationStatus @default(pending)
  invitedByUserId String
  invitedBy       User             @relation(fields: [invitedByUserId], references: [id])
  employeeId      String?
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
}
